:- object(iso_8859_1,
	imports(single_byte_character_set(0xFF))).

	:- info([
		version is 1:0:0,
		author is 'Paulo Moura',
		date is 2026-04-05,
		comment is 'ISO-8859-1 character set encoder and decoder.'
	]).

	preferred_mime_name('ISO-8859-1').

	name('ISO_8859-1:1987').

	alias('iso-ir-100').
	alias('ISO_8859-1').
	alias(latin1).
	alias(l1).
	alias('IBM819').
	alias('CP819').
	alias('csISOLatin1').

	mibenum(4).

:- end_object.


